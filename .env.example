# Gemini API keys. The app tries GEMINI_API_KEY_1..9 in order, then falls
# back to a single GEMINI_API_KEY. Provide as many as you have for rotation.
GEMINI_API_KEY_1=your_first_gemini_api_key_here
GEMINI_API_KEY_2=your_second_gemini_api_key_here

# Single-key setup (used if the numbered keys above are not set):
# GEMINI_API_KEY=your_gemini_api_key_here
